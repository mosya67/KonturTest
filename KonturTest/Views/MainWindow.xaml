<Window x:Class="KonturTest.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KonturTest"
        xmlns:viewmodels="clr-namespace:KonturTest.ViewModels"
        d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel}"
        mc:Ignorable="d"
        Title="MainWindow"
        Height="300"
        Width="600"
        MinHeight="200"
        MinWidth="400">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Вкладки  -->
        <TabControl Grid.Row="0">

            <!-- Вкладка 1 -->
            <TabItem Header="вкладка 1">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Content="DataFile:" Grid.Column="0" Grid.Row="0" Margin="0,2"/>
                        <Button Content="Открыть" Grid.Column="1" Grid.Row="0" Margin="5,2" Padding="10,2" Command="{Binding Module1.OpenDataCommand}"/>
                        <TextBox Grid.Column="2" Grid.Row="0" Margin="5,2" Padding="2,5" Text="{Binding Module1.DataFilePath, UpdateSourceTrigger=PropertyChanged}"/>

                        <Label Content="CsvFile:" Grid.Column="0" Grid.Row="1" Margin="0,2"/>
                        <Button Content="Открыть" Grid.Column="1" Grid.Row="1" Margin="5,2" Padding="10,2" Command="{Binding Module1.OpenCsvCommand}"/>
                        <TextBox Grid.Column="2" Grid.Row="1" Margin="5,2" Padding="2,5" Text="{Binding Module1.CsvFilePath, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <Button Content="Запустить процесс" HorizontalAlignment="Stretch" Grid.Row="1" Margin="5,2" Padding="10,2" Command="{Binding Module1.StartCommand}" IsEnabled="{Binding Module1.IsButtonEnabled}"/>
                    <ProgressBar Grid.Row="2" Minimum="0" Maximum="100" Height="20" Margin="5, 2" Value="{Binding Module1.ProgressValue}"/>
                </Grid>
            </TabItem>
            
            
            <!-- Вкладка 2 -->
            <TabItem Header="вкладка 2">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Content="DataFile:" Grid.Column="0" Grid.Row="0" Margin="0,2"/>
                        <Button Content="Открыть" Grid.Column="1" Grid.Row="0" Margin="5,2" Padding="10,2" Command="{Binding Module2.OpenDataCommand}"/>
                        <TextBox Grid.Column="2" Grid.Row="0" Margin="5,2" Padding="2,5" Text="{Binding Module2.DataFilePath, UpdateSourceTrigger=PropertyChanged}"/>

                        <Label Content="CsvFile:" Grid.Column="0" Grid.Row="1" Margin="0,2"/>
                        <Button Content="Открыть" Grid.Column="1" Grid.Row="1" Margin="5,2" Padding="10,2" Command="{Binding Module2.OpenCsvCommand}"/>
                        <TextBox Grid.Column="2" Grid.Row="1" Margin="5,2" Padding="2,5" Text="{Binding Module2.CsvFilePath, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <Button Content="Запустить процесс" HorizontalAlignment="Stretch" Grid.Row="1" Margin="5,2" Padding="10,2" Command="{Binding Module2.StartCommand}" IsEnabled="{Binding Module2.IsButtonEnabled}"/>
                    <ProgressBar Grid.Row="2" Minimum="0" Maximum="100" Height="20" Margin="5, 2" Value="{Binding Module2.ProgressValue}"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
